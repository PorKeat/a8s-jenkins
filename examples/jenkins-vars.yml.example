---
# Copy this file to a vault-encrypted vars file and replace placeholders
# before applying the role.

jenkins_admin_username: "replace-me"
jenkins_admin_password: "replace-me"
jenkins_admin_full_name: "Autonomous Istad Jenkins Admin"
jenkins_admin_email: "devops@example.com"
jenkins_url: "https://jenkins.autonomous-istad.com"

jenkins_username_password_credentials:
  - id: a8s-backend-credential
    description: SCM credential for a8s-backend and a8s-admin
    username: "replace-me"
    password: "replace-me"
  - id: a8s-frontend-credential
    description: SCM credential for a8s-frontend
    username: "replace-me"
    password: "replace-me"
  - id: registry-credentials
    description: Container registry credential
    username: "replace-me"
    password: "replace-me"
  - id: DOCKERHUB-CREDENTIAL
    description: Docker Hub credential
    username: "replace-me"
    password: "replace-me"

jenkins_string_credentials:
  - id: sonarqube-token
    description: SonarQube token
    secret: "replace-me"
  - id: DEFECTDOJO
    description: DefectDojo API token or secret text
    secret: "replace-me"
  - id: registry-url
    description: Registry URL
    secret: "replace-me"
  - id: registry-repository
    description: Registry repository
    secret: "replace-me"
  - id: gitops-repo-url
    description: GitOps repository URL
    secret: "replace-me"
  - id: infra-repo-url
    description: Infrastructure repository URL
    secret: "replace-me"
  - id: infra-repo-url-micro
    description: Microservices infrastructure repository URL
    secret: "replace-me"
  - id: registry-repository-micro
    description: Microservices registry repository
    secret: "replace-me"
  - id: gitops-repo-url-micro
    description: Microservices GitOps repository URL
    secret: "replace-me"
  - id: register-url-micro
    description: Microservices registry URL
    secret: "replace-me"
  - id: a8s-admin-github-token
    description: GitHub token used by a8s-admin
    secret: "replace-me"

jenkins_ssh_private_key_credentials:
  - id: gitops-ssh
    description: GitOps SSH credential
    username: git
    private_key: |
      -----BEGIN OPENSSH PRIVATE KEY-----
      replace-me
      -----END OPENSSH PRIVATE KEY-----
