{% set ns = namespace(
  active_string_credentials=[],
  active_file_credentials=[],
  active_scm_token_credentials=[],
  active_username_password_credentials=[],
  active_ssh_credentials=[]
) %}
{% for item in jenkins_string_credentials %}
{% set secret_value = item.secret | default('') | string | trim %}
{% if secret_value and secret_value != 'replace-me' %}
{% set ns.active_string_credentials = ns.active_string_credentials + [item] %}
{% endif %}
{% endfor %}
{% for item in jenkins_file_credentials %}
{% set file_content = item.content | default(item.secret_text | default('')) | string | trim %}
{% if file_content and file_content != 'replace-me' %}
{% set ns.active_file_credentials = ns.active_file_credentials + [item] %}
{% endif %}
{% endfor %}
{% for item in jenkins_scm_token_credentials %}
{% set scm_token = item.token | default('') | string | trim %}
{% set scm_username = item.username | default(jenkins_scm_token_default_username) | string | trim %}
{% if scm_token and scm_token != 'replace-me' and scm_username and scm_username != 'replace-me' %}
{% set ns.active_scm_token_credentials = ns.active_scm_token_credentials + [item] %}
{% endif %}
{% endfor %}
{% for item in jenkins_username_password_credentials %}
{% set username_value = item.username | default('') | string | trim %}
{% set password_value = item.password | default('') | string | trim %}
{% if username_value and username_value != 'replace-me' and password_value and password_value != 'replace-me' %}
{% set ns.active_username_password_credentials = ns.active_username_password_credentials + [item] %}
{% endif %}
{% endfor %}
{% for item in jenkins_ssh_private_key_credentials %}
{% set private_key_value = item.private_key | default('') | string | trim %}
{% if private_key_value and 'replace-me' not in private_key_value %}
{% set ns.active_ssh_credentials = ns.active_ssh_credentials + [item] %}
{% endif %}
{% endfor %}
import com.cloudbees.jenkins.plugins.sshcredentials.SSHUserPrivateKey
import com.cloudbees.jenkins.plugins.sshcredentials.impl.BasicSSHUserPrivateKey
import com.cloudbees.plugins.credentials.Credentials
import com.cloudbees.plugins.credentials.CredentialsScope
import com.cloudbees.plugins.credentials.SystemCredentialsProvider
import com.cloudbees.plugins.credentials.common.StandardUsernamePasswordCredentials
import com.cloudbees.plugins.credentials.SecretBytes
import com.cloudbees.plugins.credentials.domains.Domain
import com.cloudbees.plugins.credentials.impl.UsernamePasswordCredentialsImpl
import hudson.util.Secret
import java.nio.charset.StandardCharsets
import jenkins.model.Jenkins
import org.jenkinsci.plugins.plaincredentials.FileCredentials
import org.jenkinsci.plugins.plaincredentials.StringCredentials
import org.jenkinsci.plugins.plaincredentials.impl.FileCredentialsImpl
import org.jenkinsci.plugins.plaincredentials.impl.StringCredentialsImpl

def overwriteExisting = {{ jenkins_credentials_overwrite_existing | bool | string | lower }}
def jenkins = Jenkins.get()
def provider = SystemCredentialsProvider.getInstance()
def store = provider.getStore()
def globalDomain = Domain.global()
def currentCredentials = provider.getCredentials()
def currentById = currentCredentials.findAll { credential ->
    try {
        credential.id
    } catch (MissingPropertyException ignored) {
        false
    }
}.collectEntries { credential -> [(credential.id): credential] }

def normalizeValue = { value ->
    value == null ? '' : value.toString().trim()
}

def isPlaceholderValue = { value ->
    def text = normalizeValue(value)
    !text || text == 'replace-me'
}

def fileSecretAsString = { credential ->
    try {
        def bytes = credential?.secretBytes?.plainData
        if (bytes == null) {
            return ''
        }
        return new String(bytes, StandardCharsets.UTF_8)
    } catch (Exception ignored) {
        return ''
    }
}

def shouldReplaceExisting = { Credentials existing, String expectedKind ->
    if (!existing) {
        return false
    }

    switch (expectedKind) {
        case 'string':
            if (!(existing instanceof StringCredentials)) {
                return true
            }
            return isPlaceholderValue(existing.secret?.plainText)

        case 'file':
            if (!(existing instanceof FileCredentials)) {
                return true
            }
            return isPlaceholderValue(fileSecretAsString(existing))

        case 'usernamePassword':
            if (!(existing instanceof StandardUsernamePasswordCredentials)) {
                return true
            }
            return isPlaceholderValue(existing.username) || isPlaceholderValue(existing.password?.plainText)

        case 'ssh':
            if (!(existing instanceof SSHUserPrivateKey)) {
                return true
            }
            def firstKey = ''
            try {
                firstKey = normalizeValue((existing.privateKeys ?: [''])[0])
            } catch (Exception ignored) {
                firstKey = ''
            }
            return isPlaceholderValue(existing.username) || !firstKey || firstKey.contains('replace-me')

        default:
            return false
    }
}

def upsertCredential = { String id, String expectedKind, Closure factory ->
    def existing = currentById[id]
    def replaceExisting = overwriteExisting || shouldReplaceExisting(existing, expectedKind)
    if (existing && !replaceExisting) {
        return false
    }
    if (existing) {
        store.removeCredentials(globalDomain, existing)
        currentById.remove(id)
    }
    def credential = factory.call()
    store.addCredentials(globalDomain, credential)
    currentById[id] = credential
    return true
}

def changed = false

{% for item in ns.active_string_credentials %}
changed = upsertCredential({{ item.id | to_json }}, 'string') {
    new StringCredentialsImpl(
        CredentialsScope.GLOBAL,
        {{ item.id | to_json }},
        {{ item.description | default('Managed by Ansible') | to_json }},
        Secret.fromString({{ item.secret | to_json }})
    )
} || changed
{% endfor %}

{% for item in ns.active_file_credentials %}
changed = upsertCredential({{ item.id | to_json }}, 'file') {
    new FileCredentialsImpl(
        CredentialsScope.GLOBAL,
        {{ item.id | to_json }},
        {{ item.description | default('Managed by Ansible') | to_json }},
        {{ item.file_name | default('env') | to_json }},
        SecretBytes.fromRawBytes({{ item.content | default(item.secret_text | default('')) | to_json }}.getBytes(StandardCharsets.UTF_8))
    )
} || changed
{% endfor %}

{% for item in ns.active_scm_token_credentials %}
changed = upsertCredential({{ item.id | to_json }}, 'usernamePassword') {
    new UsernamePasswordCredentialsImpl(
        CredentialsScope.GLOBAL,
        {{ item.id | to_json }},
        {{ item.description | default('Managed by Ansible') | to_json }},
        {{ item.username | default(jenkins_scm_token_default_username) | to_json }},
        {{ item.token | to_json }}
    )
} || changed
{% endfor %}

{% for item in ns.active_username_password_credentials %}
changed = upsertCredential({{ item.id | to_json }}, 'usernamePassword') {
    new UsernamePasswordCredentialsImpl(
        CredentialsScope.GLOBAL,
        {{ item.id | to_json }},
        {{ item.description | default('Managed by Ansible') | to_json }},
        {{ item.username | to_json }},
        {{ item.password | to_json }}
    )
} || changed
{% endfor %}

{% for item in ns.active_ssh_credentials %}
changed = upsertCredential({{ item.id | to_json }}, 'ssh') {
    new BasicSSHUserPrivateKey(
        CredentialsScope.GLOBAL,
        {{ item.id | to_json }},
        {{ item.username | default('git') | to_json }},
        new BasicSSHUserPrivateKey.DirectEntryPrivateKeySource({{ item.private_key | to_json }}),
        null,
        {{ item.description | default('Managed by Ansible') | to_json }}
    )
} || changed
{% endfor %}

if (changed) {
    provider.save()
    jenkins.save()
    println('CHANGED')
} else {
    println('UNCHANGED')
}
