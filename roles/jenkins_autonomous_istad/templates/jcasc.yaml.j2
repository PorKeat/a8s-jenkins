jenkins:
  systemMessage: {{ jenkins_system_message | to_json }}
  mode: NORMAL
  numExecutors: {{ jenkins_controller_executors | int }}
  slaveAgentPort: {{ jenkins_agent_port | int }}
  remotingSecurity:
    enabled: true
  crumbIssuer:
    standard: {}
  securityRealm:
    local:
      allowsSignup: false
      users:
        - id: {{ jenkins_admin_username | to_json }}
          name: {{ jenkins_admin_full_name | to_json }}
          password: {{ jenkins_admin_password | to_json }}
  authorizationStrategy:
    loggedInUsersCanDoAnything:
      allowAnonymousRead: false
{% if jenkins_agents | length > 0 %}
  nodes:
{% for agent in jenkins_agents %}
    - permanent:
        name: {{ agent.name | to_json }}
        labelString: {{ agent.label | to_json }}
        mode: {{ agent.mode | default('NORMAL') | to_json }}
        numExecutors: {{ agent.executors | int }}
        remoteFS: {{ agent.remote_fs | to_json }}
        nodeDescription: {{ agent.description | default('Managed by Ansible') | to_json }}
        retentionStrategy: "always"
        launcher:
{% if agent.launcher is defined and agent.launcher.type | default('inbound') == 'ssh' %}
          ssh:
            credentialsId: {{ agent.launcher.credentials_id | to_json }}
            host: {{ agent.launcher.host | to_json }}
{% if agent.launcher.java_path is defined and agent.launcher.java_path %}
            javaPath: {{ agent.launcher.java_path | to_json }}
{% endif %}
{% if agent.launcher.jvm_options is defined and agent.launcher.jvm_options %}
            jvmOptions: {{ agent.launcher.jvm_options | to_json }}
{% endif %}
{% if agent.launcher.launch_timeout_seconds is defined %}
            launchTimeoutSeconds: {{ agent.launcher.launch_timeout_seconds | int }}
{% endif %}
{% if agent.launcher.max_num_retries is defined %}
            maxNumRetries: {{ agent.launcher.max_num_retries | int }}
{% endif %}
            port: {{ agent.launcher.port | default(22) | int }}
{% if agent.launcher.prefix_start_slave_cmd is defined and agent.launcher.prefix_start_slave_cmd %}
            prefixStartSlaveCmd: {{ agent.launcher.prefix_start_slave_cmd | to_json }}
{% endif %}
{% if agent.launcher.retry_wait_time is defined %}
            retryWaitTime: {{ agent.launcher.retry_wait_time | int }}
{% endif %}
            sshHostKeyVerificationStrategy:
              {{ agent.launcher.ssh_host_key_verification_strategy | default('nonVerifyingKeyVerificationStrategy') }}: {}
{% else %}
          inbound:
            webSocket: {{ agent.launcher.web_socket | default(agent.web_socket | default(false)) | string | lower }}
{% endif %}
{% endfor %}
{% endif %}

unclassified:
  location:
    adminAddress: {{ jenkins_admin_email | to_json }}
    url: {{ (jenkins_url.rstrip('/') ~ '/') | to_json }}

{% if jenkins_sonar_scanner_installations | length > 0 %}
tool:
  sonarRunnerInstallation:
    installations:
{% for installation in jenkins_sonar_scanner_installations %}
      - name: {{ installation.name | to_json }}
{% if installation.home is defined and installation.home %}
        home: {{ installation.home | to_json }}
{% endif %}
{% if installation.installer_id is defined and installation.installer_id %}
        properties:
          - installSource:
              installers:
                - sonarRunnerInstaller:
                    id: {{ installation.installer_id | to_json }}
{% endif %}
{% endfor %}
{% endif %}

{% if jenkins_manage_jobs | bool %}
jobs:
  - script: |
{{ jenkins_job_dsl_script | indent(6, true) }}
{% endif %}
